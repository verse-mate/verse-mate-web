{
  "name": "verse-mate-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun run next dev --turbo",
    "build": "bun --bun run next build",
    "build:worker": "opennextjs-cloudflare build",
    "start": "bun --bun run .next/standalone/server.js",
    "deploy": "opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write --no-errors-on-unmatched .",
    "format": "biome format --write .",
    "tsc": "bunx tsc",
    "stylelint": "stylelint \"{src,packages}/**/*.css\"",
    "validate": "bun run lint && bun run tsc",
    "prepare": "husky install"
  },
  "workspaces": ["packages/*"],
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@tanstack/react-query": "^5.59.15",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.3",
    "driver.js": "^1.3.6",
    "frontend-base": "workspace:*",
    "frontend-envs": "workspace:*",
    "next": "^15.4.8",
    "posthog-js": "^1.298.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@opennextjs/cloudflare": "^1.6.5",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.14.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "bun-types": "^1.1.21",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "postcss-nested": "^6.2.0",
    "sharp": "^0.34.3",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "wrangler": "^4.28.1"
  },
  "resolutions": {
    "@elysiajs/eden": "1.4.1",
    "elysia": "1.4.9",
    "esbuild": "0.25.0",
    "nanostores": "0.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@swc/core",
    "esbuild",
    "msw",
    "sharp"
  ],
  "packageManager": "bun@1.2.23"
}
