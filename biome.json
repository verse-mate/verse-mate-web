{
  "$schema": "https://biomejs.dev/schemas/1.5.2/schema.json",
  "files": {
    "ignore": [
      ".docker",
      "out",
      "dist",
      "generated",
      ".next",
      ".vscode",
      "mockServiceWorker.js",
      "handlers.ts",
      "./packages/backend-base/src/bible/data/t_asv.json",
      "./packages/backend-base/src/bible/data/NASB1995.json",
      "./apps/frontend-next/public/*",
      "./apps/website/*",
      "./VerseMate/*",
      "./apps/lovable/*"
    ],
    "maxSize": 6000000
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "complexity": {
        "noForEach": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentWidth": 2,
    "indentStyle": "space"
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  }
}
