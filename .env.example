# VerseMate frontend env vars (copy to .env.local for local dev)

# Base URL for the VerseMate backend API.
# Defaults to production (https://api.versemate.org) if not set.
VITE_API_URL=https://api.versemate.org

# Google OAuth client id used by the Google Identity Services popup flow.
# Defaults to the VerseMate production client id. You generally don't need
# to change this unless you're running against a different Google project.
# NOTE: the JavaScript origin for wherever this app is served (e.g. your
# Lovable preview URL or deployed domain) must be added under
# "Authorized JavaScript origins" in the Google Cloud Console for the
# OAuth client, or Google Sign-In will fail with "not a valid origin".
VITE_GOOGLE_CLIENT_ID=94126503648-2fb9dakdfi8pmi8ep78bk5nsrv94db6o.apps.googleusercontent.com
