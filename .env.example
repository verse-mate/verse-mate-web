API_URL=http://localhost:4000
APP_URL=http://localhost:3000

NEXT_PUBLIC_ASK_VERSE_MATE=false

# Deep Linking Feature Flag
# Set to "true" to enable automatic app opening when mobile users visit Bible chapter URLs
# This should be disabled until the mobile app is published to app stores
# When enabled, mobile users will see a redirect to the app after 2.5 seconds
NEXT_PUBLIC_DEEP_LINKING_ENABLED=false

# SSO Feature Flags (set to "true" to enable)
NEXT_PUBLIC_SSO_GOOGLE_ENABLED=false
NEXT_PUBLIC_SSO_APPLE_ENABLED=false

# PostHog Analytics Configuration (Frontend/Client-side)
# Get your API key from https://app.posthog.com/project/settings
# Leave empty to disable PostHog tracking (recommended for local development)
# IMPORTANT: Use separate PostHog projects for dev/staging vs production environments
POSTHOG_KEY=
# PostHog host URL (default: https://app.posthog.com for PostHog Cloud)
# Only change this if using self-hosted PostHog or EU cloud (https://eu.posthog.com)
POSTHOG_HOST=https://app.posthog.com
# Enable session replay recording (set to 'true' to enable)
# Session replay captures user interactions for debugging and UX analysis
# IMPORTANT: Session replay should be disabled in development to:
# - Reduce noise in analytics data
# - Minimize performance overhead during development
# - Avoid capturing sensitive development data
# Recommended: false for development, true for production
POSTHOG_SESSION_REPLAY=false
